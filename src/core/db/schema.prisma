generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum ScheduleStatus {
  PENDING
  COMPLETED
  FAILED
}

model Schedules {
  id          String         @id @default(uuid())
  postName    String
  status      ScheduleStatus
  runAt       DateTime
  lockedUntil DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("Schedules")
}

model CompletedSchedules {
  id         String @id @default(uuid())
  scheduleId String @unique

  @@map("CompletedSchedules")
}
